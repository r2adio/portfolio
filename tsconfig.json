{
  "extends": "astro/tsconfigs/strictest",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [ "dist" ],
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "paths": {
      "@components/*": [ "./src/components/*" ],
      "@layouts/*": [ "./src/layouts/*" ],
      "@assets/*": [ "./src/assets/*" ],
      "@styles/*": [ "./src/styles/*" ],
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
